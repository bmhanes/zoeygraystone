# ── Zoey Environment Variables ────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# For passwords and secrets, ensure you use strong, unique values. 
# Try running "openssl rand -hex 32" to generate a strong secret
# Never share them publicly or commit them to version control.
# API Keys are not RANDOM and should be kept secret. Do not share them or commit them to version control.

# ── Anthropic (Claude - Advanced Mode) ────────────────────────────────────────
# Sign up for an API key at https://www.anthropic.com/ and replace the value below.
# Key format example: "sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_EXPRESS_PASSWORD=changeme_before_use

 
# ── LDAP / Active Directory (ServerName) # Replace with your actual LDAP settings ────────────────────────────────────────────
# All Values below are examples. Replace them with your actual LDAP/AD settings.
# For LDAP_SERVER, use ldap://<IP_ADDRESS> for IPv4 or ldap://[<IP_ADDRESS>] for IPv6.
# <DCNAME> is the domain component of your LDAP/AD, often derived from your domain name. 
# For example, if your domain is "example.com", your DCNAME would be "example". 
# If your domain is "mydomain.local", your DCNAME would be "mydomain". 
# Adjust accordingly based on your actual domain structure.
#
# Example LDAP_SERVER values:
LDAP_SERVER=ldap://10.242.1.5     #  (Change to your LDAP IP. Use ldap://<IP_ADDRESS> for IPv4)
LDAP_DOMAIN=GRAYSTONE.SOLUTIONS   #  (e.g., "example.com" or "mydomain.local")
LDAP_ADMIN_DN=CN=Administrator,CN=Users,DC=<DCNAME>,DC=local  # (Replace with your DC Information)
LDAP_ADMIN_PASSWORD=changeme_before_use     # (Replace with your LDAP Admin Password)     
LDAP_BASE_DN=DC=<DCNAME>,DC=local    # (Replace with your Information)
ZOEY_AD_GROUP=zoey_users          # (Must Create User Group "zoey_users" or similar in your DC)

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string 
JWT_EXPIRY_HOURS=8  # Token expiry time in hours. Adjust as needed.

# ── Ollama (Local Mixtral - Standard Mode) ────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mixtral:8x7b