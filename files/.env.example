# ── Zoey Environment Variables ────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Anthropic (Claude - Advanced Mode) ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Mistral API (Standard Mode) ───────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ── MongoDB / Cosmos DB ────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/zoey

# ── Microsoft Entra ID (OAuth2) ───────────────────────────────────────────────
# Found in: Azure Portal → Entra ID → App registrations → Zoey → Overview
ENTRA_TENANT_ID=your_tenant_id_here
ENTRA_CLIENT_ID=your_client_id_here
ENTRA_CLIENT_SECRET=your_client_secret_here

# Redirect URI — must match exactly what is registered in Azure Portal
# Dev:  http://localhost:8000/auth/callback
# Prod: https://zoey.graystone.solutions/auth/callback
ENTRA_REDIRECT_URI=http://localhost:8000/auth/callback

# AD group required for Zoey access
ZOEY_AD_GROUP=zoey_users

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRY_HOURS=8

# ── Ollama (optional - local inference) ───────────────────────────────────────
# Leave blank to use Mistral API instead
OLLAMA_URL=
OLLAMA_MODEL=mixtral:8x7b
